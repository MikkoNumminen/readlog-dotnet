@using Microsoft.AspNetCore.Identity
@using ReadLog.Web.Auth
@using ReadLog.Web.Models
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item d-flex align-items-center">
            <span class="navbar-text me-2">@(User.FindFirst(DisplayNameClaimsPrincipalFactory.DisplayNameClaim)?.Value ?? User.Identity?.Name)</span>
        </li>
        <li class="nav-item">
            <form method="post" asp-page="/Account/Logout">
                <button type="submit" class="btn btn-link nav-link">Sign out</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-page="/Account/Login">Sign in</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Account/Register">Create account</a>
        </li>
    }
</ul>
