@page
@using ReadLog.Web.Models
@model LibraryModel
@{
    ViewData["Title"] = "My Library";
}

<div class="rl-medium">
    <h1 class="rl-page-title">My Library</h1>

    <form method="get" class="mb-3" role="search">
        <label for="q" class="form-label">Have I read this?</label>
        <input type="search" id="q" name="q" value="@Model.Query" class="form-control"
               placeholder="Search your library…" />
    </form>

    @if (Model.Searched)
    {
        @if (Model.SearchResults.Count == 0)
        {
            <p class="text-muted">Not in your library.</p>
        }
        else
        {
            <p class="text-success fw-semibold mb-2">
                Yes! Found @Model.SearchResults.Count match@(Model.SearchResults.Count == 1 ? "" : "es"):
            </p>
            <div class="d-flex flex-column gap-2 mb-4">
                @foreach (var result in Model.SearchResults)
                {
                    <div class="card"><div class="card-body d-flex align-items-center gap-2 py-2">
                        @if (!string.IsNullOrEmpty(result.Book.CoverUrl))
                        {
                            <img class="rl-cover rl-cover-sm" src="@result.Book.CoverUrl" alt="@result.Book.Title" loading="lazy" />
                        }
                        <div>
                            <div class="fw-semibold">@result.Book.Title</div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge rl-format-badge">@result.Format.Icon() @result.Format.Label()</span>
                                <span class="text-muted small">@result.FinishedAt.ToString("MMM d, yyyy")</span>
                            </div>
                        </div>
                    </div></div>
                }
            </div>
        }
    }

    @if (Model.Entries.Count == 0)
    {
        <p class="text-muted text-center mt-5">No books logged yet. Start by logging your first book!</p>
    }
    else
    {
        <div class="d-flex justify-content-end gap-2 mb-2">
            <a class="btn btn-sm @(Model.View == "grid" ? "btn-primary" : "btn-outline-primary")"
               asp-route-view="grid" asp-route-q="@Model.Query">Grid</a>
            <a class="btn btn-sm @(Model.View == "list" ? "btn-primary" : "btn-outline-primary")"
               asp-route-view="list" asp-route-q="@Model.Query">List</a>
        </div>

        @if (Model.View == "list")
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var entry in Model.Entries)
                {
                    <div class="card"><div class="card-body d-flex align-items-center gap-2 py-2">
                        @if (!string.IsNullOrEmpty(entry.Book.CoverUrl))
                        {
                            <img class="rl-cover rl-cover-sm" src="@entry.Book.CoverUrl" alt="@entry.Book.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="rl-cover rl-cover-sm rl-cover-placeholder">📖</div>
                        }
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold text-truncate">@entry.Book.Title</div>
                            @if (!string.IsNullOrEmpty(entry.Book.Author))
                            {
                                <div class="text-muted small text-truncate">@entry.Book.Author</div>
                            }
                            <partial name="_Stars" model="entry.Rating" />
                        </div>
                        <span class="badge rl-format-badge">@entry.Format.Icon() @entry.Format.Label()</span>
                        <span class="text-muted small d-none d-sm-inline">@entry.FinishedAt.ToString("MMM d, yyyy")</span>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Library/Edit" asp-route-id="@entry.Id">Edit</a>
                    </div></div>
                }
            </div>
        }
        else
        {
            <div class="row row-cols-3 row-cols-sm-4 row-cols-md-5 g-3">
                @foreach (var entry in Model.Entries)
                {
                    <div class="col">
                        <a class="text-decoration-none text-reset rl-grid-item" asp-page="/Library/Edit" asp-route-id="@entry.Id">
                            @if (!string.IsNullOrEmpty(entry.Book.CoverUrl))
                            {
                                <img class="rl-cover rl-cover-grid" src="@entry.Book.CoverUrl" alt="@entry.Book.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="rl-cover rl-cover-grid rl-cover-placeholder">📖</div>
                            }
                            <div class="small fw-semibold mt-1 rl-clamp-2">@entry.Book.Title</div>
                            @if (!string.IsNullOrEmpty(entry.Book.Author))
                            {
                                <div class="text-muted text-truncate" style="font-size:.75rem">@entry.Book.Author</div>
                            }
                            <partial name="_Stars" model="entry.Rating" />
                        </a>
                    </div>
                }
            </div>
        }
    }
</div>
