@page
@model ErrorModel
@{
    ViewData["Title"] = Model.StatusCodeValue == 404 ? "Page not found" : "Error";
}

@if (Model.StatusCodeValue == 404)
{
    <h1 class="text-danger">Page not found</h1>
    <p>We couldn't find the page you were looking for.</p>
}
else
{
    <h1 class="text-danger">Something went wrong.</h1>
    <h2 class="text-danger">An error occurred while processing your request.</h2>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }
}

<p>
    <a asp-page="/Index">Return home</a>
</p>
