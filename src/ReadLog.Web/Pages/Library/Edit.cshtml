@page "{id:int}"
@using ReadLog.Web.Models
@model ReadLog.Web.Pages.Library.EditModel
@{
    ViewData["Title"] = "Edit entry";
}

<div class="rl-narrow">
    <h1 class="rl-page-title">Edit entry</h1>

    @if (Model.Book is not null)
    {
        <div class="d-flex align-items-center gap-2 mb-3 text-muted">
            @if (!string.IsNullOrEmpty(Model.Book.CoverUrl))
            {
                <img class="rl-cover rl-cover-sm" src="@Model.Book.CoverUrl" alt="" />
            }
            <span class="small">
                Editing your entry@(string.IsNullOrEmpty(Model.Book.Author) ? "" : $" · {Model.Book.Author}")
            </span>
        </div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="Input.Title" class="form-label">Title</label>
            <input asp-for="Input.Title" class="form-control" />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>

        <fieldset class="mb-3">
            <legend class="form-label">Format</legend>
            <div class="btn-group">
                @foreach (var format in new[] { Format.Book, Format.Audiobook, Format.Ebook })
                {
                    <input type="radio" class="btn-check" name="Input.Format" id="fmt-@format"
                           value="@format" autocomplete="off" checked="@(Model.Input.Format == format)" />
                    <label class="btn btn-outline-primary" for="fmt-@format">@format.Icon() @format.Label()</label>
                }
            </div>
        </fieldset>

        <div class="mb-3">
            <label asp-for="Input.FinishedAt" class="form-label"></label>
            <input asp-for="Input.FinishedAt" type="date" class="form-control" />
            <span asp-validation-for="Input.FinishedAt" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Rating" class="form-label">Rating</label>
            <select asp-for="Input.Rating" class="form-select">
                <option value="">No rating</option>
                <option value="1">★ 1</option>
                <option value="2">★★ 2</option>
                <option value="3">★★★ 3</option>
                <option value="4">★★★★ 4</option>
                <option value="5">★★★★★ 5</option>
            </select>
            <span asp-validation-for="Input.Rating" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-page="/Library">Cancel</a>
            </div>
        </div>
    </form>

    <form method="post" asp-page-handler="Delete" class="mt-3"
          data-confirm="Delete this entry?">
        <button type="submit" class="btn btn-outline-danger btn-sm">Delete entry</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
